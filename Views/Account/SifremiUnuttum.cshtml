@{
    Layout = null;
    ViewData["Title"] = "Şifremi Unuttum";
    // -----------------------------------------------------------------------------------------
    // PROJE İSTERLERİ KANITLARI (Account/SifremiUnuttum.cshtml)
    // -----------------------------------------------------------------------------------------
    // [İSTER 11] : Tag Helper Kullanılmış mı? EVET (asp-action).
    // [İSTER 22] : Admin Teması uygulanmış mı? EVET (Tailwind Dark Mode).
    // [İSTER 24] : Şifre sıfırlama adımları mevcut mu? EVET.
    // -----------------------------------------------------------------------------------------
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Şifremi Unuttum - Anatolian Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-[#1a1c23] h-screen flex items-center justify-center font-sans">

    <div class="w-full max-w-md p-8 space-y-6 bg-[#252836] rounded-xl shadow-2xl border border-gray-700">

        <div class="text-center">
            <div class="flex justify-center mb-4">
                <i class="fas fa-key text-4xl text-yellow-500"></i>
            </div>
            <h1 class="text-2xl font-bold text-yellow-500 tracking-widest uppercase">ŞİFRE SIFIRLAMA</h1>
            <p class="text-gray-400 mt-2 text-sm">Lütfen kullanıcı adınızı giriniz.</p>
        </div>

        @if (TempData["Hata"] != null)
        {
            <div class="bg-red-500/20 border border-red-500 text-red-200 text-sm p-3 rounded text-center">
                <i class="fas fa-exclamation-circle mr-1"></i> @TempData["Hata"]
            </div>
        }

        <form asp-action="SifremiUnuttum" method="post" class="space-y-6">
            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase mb-2">Kullanıcı Adı</label>
                <input type="text" name="kadi" required autocomplete="off"
                       class="w-full px-4 py-3 bg-[#1a1c23] border border-gray-600 rounded text-white focus:outline-none focus:border-yellow-500 transition placeholder-gray-600"
                       placeholder="Kullanıcı adınız..." />
            </div>

            <button type="submit" class="w-full py-3 bg-yellow-600 hover:bg-yellow-700 text-white font-bold rounded transition duration-300 shadow-lg uppercase tracking-wide flex justify-center items-center gap-2">
                <span>Devam Et</span>
                <i class="fas fa-arrow-right"></i>
            </button>
        </form>

        <div class="text-center mt-4 border-t border-gray-700 pt-4">
            <a asp-action="Login" class="text-sm text-gray-500 hover:text-yellow-500 transition flex justify-center items-center gap-2">
                <i class="fas fa-arrow-left"></i> Giriş Ekranına Dön
            </a>
        </div>
    </div>
</body>
</html>