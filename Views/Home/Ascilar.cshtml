@using RestoranProje1.Extensions
@model List<RestoranProje1.Models.Asci>

@{
    ViewData["Title"] = "Aşçılarımız";
    // -----------------------------------------------------------------------------------------
    // PROJE İSTERLERİ KANITLARI (Home/Ascilar.cshtml)
    // -----------------------------------------------------------------------------------------
    // [İSTER 9]  : MVC View katmanı mı?
    //              EVET -> Kullanıcıya verilerin sunulduğu arayüz dosyasıdır.
    //
    // [İSTER 14] : Razor Syntax Kullanılmış mı?
    //              EVET -> @if, @foreach ve @Model yapıları kullanılmıştır.
    //
    // [İSTER 10] : Custom Html Helper Kullanılmış mı?
    //              EVET -> Aşağıda @Html.MetinKisalt(...) kullanılarak biyografi metni
    //              belli bir karakterden sonra "..." ile kısaltılmıştır.
    // -----------------------------------------------------------------------------------------
}

<section class="relative h-[40vh] flex items-center justify-center bg-black">
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1577219491135-ce391730fb2c?q=80&w=2577&auto=format&fit=crop')] bg-cover bg-center opacity-40"></div>
    <div class="relative z-10 text-center">
        <h1 class="font-serif text-5xl text-yellow-500 font-bold tracking-widest">LEZZET MİMARLARI</h1>
    </div>
</section>

<section class="py-24 bg-[#1a1c23]">
    <div class="max-w-7xl mx-auto px-4">

        @if (Model != null && Model.Any())
        {
            <div class="grid md:grid-cols-3 gap-12">
                @foreach (var asci in Model)
                {
                    <div class="group bg-[#252836] rounded-xl overflow-hidden border border-yellow-500/10 hover:border-yellow-500/50 transition duration-500 shadow-xl">
                        <div class="relative h-[400px] overflow-hidden">
                            <img src="@asci.AsciResimYolu" alt="@asci.AsciAdi" class="w-full h-full object-cover transition duration-700 group-hover:scale-110">
                            <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-80"></div>
                        </div>

                        <div class="p-8 text-center relative -mt-16">
                            <div class="bg-[#1a1c23] border border-yellow-500/30 p-4 rounded shadow-lg transform transition duration-300 group-hover:-translate-y-2">
                                <h3 class="text-2xl font-serif text-yellow-500 mb-1">@asci.AsciAdi @asci.AsciSoyadi</h3>
                                <p class="text-sm text-gray-400 uppercase tracking-widest mb-4">@asci.AsciUnvan</p>
                                <div class="w-12 h-px bg-yellow-500/50 mx-auto mb-4"></div>
                                <p class="text-gray-500 text-sm italic">
                                    @Html.MetinKisalt(asci.AsciBiyografi, 100)
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center text-gray-500 py-20">
                <p>Henüz aşçı kadrosu eklenmedi.</p>
            </div>
        }
    </div>
</section>