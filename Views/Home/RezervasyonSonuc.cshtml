@model List<RestoranProje1.Models.Rezervasyon>

@{
    ViewData["Title"] = "Rezervasyonlarınız";
    // -----------------------------------------------------------------------------------------
    // PROJE İSTERLERİ KANITLARI (Home/RezervasyonSonuc.cshtml)
    // -----------------------------------------------------------------------------------------
    // [İSTER 14] : Razor Syntax (Karar Yapıları)
    //              EVET -> Rezervasyon durumuna (Onaylandı/Reddedildi) göre renk değiştiren
    //              if-else blokları kullanılmıştır.
    //
    // [İSTER 22] : Özgün Web Tasarımı
    //              EVET -> Responsive tablo yapısı ve koyu tema (Dark Mode) uygulanmıştır.
    // -----------------------------------------------------------------------------------------
}

<section class="relative h-[30vh] flex items-center justify-center bg-black">
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1552566626-52f8b828add9?q=80&w=2070&auto=format&fit=crop')] bg-cover bg-center opacity-30"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#1a1c23] via-transparent to-black/60"></div>
    <div class="relative z-10 text-center">
        <h1 class="font-serif text-4xl text-yellow-500 font-bold tracking-widest drop-shadow-lg">REZERVASYONLARIM</h1>
    </div>
</section>

<section class="py-20 bg-[#1a1c23] min-h-[50vh]">
    <div class="max-w-5xl mx-auto px-4">

        <div class="mb-8 flex justify-between items-center">
            <p class="text-gray-400">
                <span class="text-white font-bold">@Model.Count</span> adet kayıt bulundu.
            </p>
            <a asp-action="RezervasyonSorgula" class="text-yellow-500 hover:text-white transition text-sm flex items-center">
                <i class="fas fa-arrow-left mr-2"></i> Yeni Sorgulama
            </a>
        </div>

        <div class="bg-[#252836] border border-yellow-500/20 rounded-xl overflow-hidden shadow-2xl">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-black/50 text-yellow-500 uppercase text-xs tracking-wider border-b border-gray-700">
                            <th class="p-4">Tarih & Saat</th>
                            <th class="p-4">İsim Soyisim</th>
                            <th class="p-4">Kişi</th>
                            <th class="p-4">Durum</th>
                            <th class="p-4">Notunuz</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-300 text-sm">
                        @foreach (var item in Model)
                        {
                            <tr class="border-b border-gray-700 hover:bg-white/5 transition">
                                <td class="p-4 font-bold text-white">
                                    @item.RezervasyonTarihi.ToString("dd.MM.yyyy") <span class="text-gray-500 ml-1">@item.RezervasyonSaati</span>
                                </td>
                                <td class="p-4">@item.MusteriAdi @item.MusteriSoyadi</td>
                                <td class="p-4">@item.KisiSayisi Kişi</td>
                                <td class="p-4">
                                    @if (item.RezervasyonDurumu == "Onaylandı")
                                    {
                                        <span class="bg-green-900/50 text-green-400 border border-green-500/30 px-3 py-1 rounded-full text-xs font-bold inline-flex items-center">
                                            <i class="fas fa-check mr-2"></i> ONAYLANDI
                                        </span>
                                    }
                                    else if (item.RezervasyonDurumu == "Reddedildi" || item.RezervasyonDurumu == "İptal")
                                    {
                                        <span class="bg-red-900/50 text-red-400 border border-red-500/30 px-3 py-1 rounded-full text-xs font-bold inline-flex items-center">
                                            <i class="fas fa-times mr-2"></i> @item.RezervasyonDurumu.ToUpper()
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="bg-yellow-900/50 text-yellow-400 border border-yellow-500/30 px-3 py-1 rounded-full text-xs font-bold inline-flex items-center">
                                            <i class="fas fa-clock mr-2"></i> BEKLİYOR
                                        </span>
                                    }
                                </td>
                                <td class="p-4 italic text-gray-500 text-xs max-w-xs truncate">
                                    @(string.IsNullOrEmpty(item.MusteriNotu) ? "-" : item.MusteriNotu)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-10 text-gray-500">
                <i class="fas fa-search text-4xl mb-3 opacity-50"></i>
                <p>Kayıtlı rezervasyon bulunamadı.</p>
            </div>
        }

    </div>
</section>