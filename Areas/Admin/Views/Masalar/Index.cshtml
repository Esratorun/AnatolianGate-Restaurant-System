@model List<RestoranProje1.Models.Masa>
@{
    ViewData["Title"] = "Masa Yönetimi";
    // -----------------------------------------------------------------------------------------
    // PROJE İSTERLERİ KANITLARI (Masa/Index.cshtml)
    // -----------------------------------------------------------------------------------------
    // [İSTER 7]  : Proje MVC tasarım kalıbına uygun geliştirilmiş mi?
    //              EVET -> Burası MVC'nin "View" katmanıdır. Controller'dan gelen liste verisini döngüyle ekrana basar.
    //
    // [İSTER 11] : Tag Helper Kullanılmış mı?
    //              EVET -> Linklemelerde "asp-action" ve parametre gönderiminde "asp-route-id" kullanılmıştır.
    //
    // [İSTER 22] : Admin için tema uygulanmış mı?
    //              EVET -> Tailwind CSS (flex, shadow, rounded vb.) kullanılarak modern bir tablo tasarımı yapılmıştır.
    //
    // [İSTER 23] : Area oluşturulmuş mu?
    //              EVET -> Bu dosya Admin Area (/Areas/Admin/Views) altındadır.
    // -----------------------------------------------------------------------------------------
}

<div class="container mx-auto px-4 py-6">

    <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-gray-800">Masa Listesi</h2>

        <a asp-action="Ekle" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold py-2 px-4 rounded shadow transition duration-300 flex items-center">
            <i class="fas fa-plus mr-2"></i> Yeni Masa Ekle
        </a>
    </div>

    @if (TempData["Basarili"] != null)
    {
        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4 shadow-sm" role="alert">
            <p class="font-bold">Başarılı!</p>
            <p>@TempData["Basarili"]</p>
        </div>
    }
    @if (TempData["Hata"] != null)
    {
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4 shadow-sm" role="alert">
            <p class="font-bold">Hata!</p>
            <p>@TempData["Hata"]</p>
        </div>
    }

    <div class="bg-white shadow-lg rounded-lg overflow-hidden border border-gray-200">

        <div class="overflow-x-auto">
            <table class="min-w-full leading-normal">
                <thead>
                    <tr>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            Masa Adı
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            Kapasite
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            Konum
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            Durum
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            İşlemler
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition duration-150">
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 w-10 h-10 bg-yellow-100 text-yellow-600 rounded-full flex items-center justify-center text-lg shadow-sm">
                                            <i class="fas fa-chair"></i>
                                        </div>
                                        <div class="ml-3">
                                            <p class="text-gray-900 font-bold whitespace-no-wrap">@item.MasaAdi</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm text-center">
                                    <span class="bg-gray-100 text-gray-800 py-1 px-3 rounded-full text-xs font-bold shadow-sm">
                                        @item.MasaKapasite Kişi
                                    </span>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm text-center">
                                    <p class="text-gray-900 whitespace-no-wrap">@item.MasaKonum</p>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm text-center">
                                    <a asp-action="DurumDegistir" asp-route-id="@item.MasaID" class="inline-block py-1 px-3 rounded-full text-xs font-bold text-white shadow-sm transition hover:opacity-80 @(item.MasaAktifMi ? "bg-green-500" : "bg-gray-400")">
                                        @(item.MasaAktifMi ? "Aktif" : "Pasif")
                                    </a>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm text-center">
                                    <div class="flex justify-center space-x-2">
                                        <a asp-action="Duzenle" asp-route-id="@item.MasaID" class="bg-blue-500 hover:bg-blue-600 text-white p-2 rounded shadow transition duration-200" title="Düzenle">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Sil" asp-route-id="@item.MasaID" onclick="return confirm('Bu masayı silmek istediğinize emin misiniz?')"
                                           class="bg-red-500 hover:bg-red-600 text-white p-2 rounded shadow transition duration-200" title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-5 py-10 border-b border-gray-200 bg-white text-sm text-center text-gray-500">
                                <div class="flex flex-col items-center justify-center">
                                    <i class="fas fa-chair text-4xl mb-4 text-gray-300"></i>
                                    <p class="text-lg font-medium">Henüz kayıtlı masa bulunmamaktadır.</p>
                                    <p class="text-sm mt-2">Yeni masa eklemek için sağ üstteki butonu kullanın.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="px-5 py-3 bg-white border-t flex flex-col xs:flex-row items-center xs:justify-between">
            <span class="text-xs xs:text-sm text-gray-900">
                Toplam <strong>@Model.Count</strong> masa listeleniyor.
            </span>
        </div>
    </div>
</div>