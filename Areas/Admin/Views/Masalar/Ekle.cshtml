@model RestoranProje1.Models.Masa
@{
    ViewData["Title"] = "Masa Ekle";
    // -----------------------------------------------------------------------------------------
    // PROJE İSTERLERİ KANITLARI (Masa/Ekle.cshtml)
    // -----------------------------------------------------------------------------------------
    // [İSTER 7]  : Proje MVC tasarım kalıbına uygun geliştirilmiş mi?
    //              EVET -> Burası MVC'nin "View" katmanıdır. Kullanıcıdan masa verilerini alır.
    //
    // [İSTER 11] : Tag Helper Kullanılmış mı?
    //              EVET -> Form oluştururken "asp-action", inputlarda "asp-for" etiketleri kullanılmıştır.
    //
    // [İSTER 15] : Server side validation Kullanılmış mı?
    //              EVET -> "asp-validation-for" etiketleri, sunucu taraflı model doğrulamalarını
    //              (Örn: Kapasite negatif olamaz) ekrana basar.
    //
    // [İSTER 16] : Client side validation Kullanılmış mı?
    //              EVET -> Sayfa altına eklenen "_ValidationScriptsPartial" sayesinde,
    //              form post edilmeden önce tarayıcı üzerinde anlık doğrulama yapılır.
    //
    // [İSTER 22] : Admin için tema uygulanmış mı?
    //              EVET -> Tailwind CSS sınıfları (shadow-lg, rounded-lg, focus:border-yellow-500)
    //              ile yönetim paneli temasına uygun tasarım yapılmıştır.
    // -----------------------------------------------------------------------------------------
}

<div class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-lg mt-10">
    <h2 class="text-2xl font-bold mb-6 text-gray-800">Yeni Masa Ekle</h2>

    <form asp-action="Ekle" method="post">
        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2 text-xs uppercase">Masa Adı / No</label>
            <input asp-for="MasaAdi" class="w-full px-3 py-2 border rounded focus:outline-none focus:border-yellow-500 transition" placeholder="Örn: Bahçe-1" />
            <span asp-validation-for="MasaAdi" class="text-red-500 text-xs font-semibold"></span>
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2 text-xs uppercase">Kapasite</label>
            <input asp-for="MasaKapasite" type="number" min="1" class="w-full px-3 py-2 border rounded focus:outline-none focus:border-yellow-500 transition" value="4" />
            <span asp-validation-for="MasaKapasite" class="text-red-500 text-xs font-semibold"></span>
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2 text-xs uppercase">Konum</label>
            <select asp-for="MasaKonum" class="w-full px-3 py-2 border rounded focus:outline-none focus:border-yellow-500 transition">
                <option value="Salon">Salon</option>
                <option value="Bahçe">Bahçe</option>
                <option value="Teras">Teras</option>
                <option value="VIP">VIP</option>
            </select>
        </div>

        <div class="flex justify-end mt-6">
            <a asp-action="Index" class="text-gray-600 mr-4 py-2 hover:text-gray-800 transition">İptal</a>
            <button type="submit" class="bg-yellow-600 text-white px-6 py-2 rounded font-bold hover:bg-yellow-700 transition shadow">Kaydet</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}