@model RestoranProje1.Models.Masa
@{
    ViewData["Title"] = "Masa Düzenle";
    // -----------------------------------------------------------------------------------------
    // PROJE İSTERLERİ KANITLARI (Masa/Duzenle.cshtml)
    // -----------------------------------------------------------------------------------------
    // [İSTER 9]  : Proje MVC tasarım kalıbına uygun geliştirilmiş mi?
    //              EVET -> Burası MVC'nin View katmanıdır. [cite_start]Model verisini kullanıcıya sunar. [cite: 9]
    //
    // [İSTER 13] : Tag Helper Kullanılmış mı?
    //              EVET -> Form oluştururken "asp-action", inputlarda "asp-for" ve validation için
    //              "asp-validation-for" yapıları kullanılmıştır. [cite: 13]
    //
    // [İSTER 15] : Server side validation Kullanılmış mı?
    //              EVET -> "asp-validation-for" etiketi, Model/Controller'dan gelen hataları basar. [cite: 15]
    //
    // [İSTER 16] : Client side validation Kullanılmış mı?
    //              EVET -> "_ValidationScriptsPartial" eklenerek tarayıcı tabanlı doğrulama aktif edilmiştir. [cite: 16]
    //
    // [İSTER 22] : Admin için tema uygulanmış mı?
    //              EVET -> Tailwind CSS (border-gray-200, shadow-lg, rounded-lg) ile tema uygulanmıştır. [cite: 22]
    //
    // [İSTER 23] : Area oluşturulmuş mu?
    //              EVET -> Bu dosya Admin Area yapısı altındadır. [cite: 23]
    // -----------------------------------------------------------------------------------------
}

<div class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-lg mt-10 border border-gray-200">
    <h2 class="text-2xl font-bold mb-6 text-gray-800 border-b pb-2">Masa Düzenle</h2>

    <form asp-action="Duzenle" method="post">
        <input type="hidden" asp-for="MasaID" />
        <input type="hidden" asp-for="MasaAktifMi" />

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2 text-xs uppercase">Masa Adı / No</label>
            <input asp-for="MasaAdi" class="w-full px-3 py-2 border rounded focus:outline-none focus:border-yellow-500 transition" placeholder="Örn: Bahçe-1" />
            <span asp-validation-for="MasaAdi" class="text-red-500 text-xs font-semibold"></span>
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2 text-xs uppercase">Kapasite</label>
            <input asp-for="MasaKapasite" type="number" min="1" class="w-full px-3 py-2 border rounded focus:outline-none focus:border-yellow-500 transition" />
            <span asp-validation-for="MasaKapasite" class="text-red-500 text-xs font-semibold"></span>
        </div>

        <div class="mb-6">
            <label class="block text-gray-700 font-bold mb-2 text-xs uppercase">Konum</label>
            <select asp-for="MasaKonum" class="w-full px-3 py-2 border rounded focus:outline-none focus:border-yellow-500 transition">
                <option value="Salon">Salon</option>
                <option value="Bahçe">Bahçe</option>
                <option value="Teras">Teras</option>
                <option value="VIP">VIP</option>
            </select>
        </div>

        <div class="flex justify-end pt-4 border-t">
            <a asp-action="Index" class="px-4 py-2 text-gray-600 hover:text-gray-800 hover:bg-gray-100 rounded transition mr-2">İptal</a>
            <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded font-bold hover:bg-blue-700 transition shadow">Güncelle</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}