@{
    ViewData["Title"] = "Anasayfa";
    // -----------------------------------------------------------------------------------------
    // PROJE İSTERLERİ KANITLARI (Dashboard/Index.cshtml)
    // -----------------------------------------------------------------------------------------
    // [İSTER 9]  : Proje MVC tasarım kalıbına uygun geliştirilmiş mi?
    //              EVET -> Burası MVC'nin "View" katmanıdır. Controller'dan "ViewBag" ile taşınan verileri kullanıcıya sunar.
    //
    // [İSTER 13] : Tag Helper Kullanılmış mı?
    //              EVET -> Linklemeler için "asp-controller" ve "asp-action" Tag Helper'ları kullanılmıştır.
    //
    // [İSTER 17] : Dependency Injection (DI) Kullanılmış mı?
    //              EVET -> Controller tarafında Constructor Injection ile dahil edilen "Singleton Servis"ten
    //              gelen anlık işlem sayısı (@ViewBag.OturumIslemSayisi) burada ekrana basılmaktadır.
    //
    // [İSTER 22] : Admin için tema uygulanmış mı?
    //              EVET -> Grid yapısı (grid-cols-4), renkli kartlar, ikonlar ve gölgelendirmeler
    //              ile yönetim paneli standartlarına uygun bir Dashboard tasarımı yapılmıştır.
    //
    // [İSTER 23] : Area oluşturulmuş mu?
    //              EVET -> Bu dosya Admin Area'sı (/Areas/Admin/Views) altında çalışmaktadır.
    // -----------------------------------------------------------------------------------------
}

<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">

    <div class="bg-white rounded-lg shadow p-5 border-l-4 border-blue-500">
        <div class="flex items-center">
            <div class="flex-shrink-0 bg-blue-100 p-3 rounded-full">
                <i class="fas fa-utensils text-blue-500 text-xl"></i>
            </div>
            <div class="ml-4">
                <h4 class="text-gray-500 text-sm">Toplam Ürün</h4>
                <p class="text-2xl font-bold text-gray-800">@ViewBag.UrunSayisi</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-5 border-l-4 border-green-500">
        <div class="flex items-center">
            <div class="flex-shrink-0 bg-green-100 p-3 rounded-full">
                <i class="fas fa-calendar-day text-green-500 text-xl"></i>
            </div>
            <div class="ml-4">
                <h4 class="text-gray-500 text-sm">Bugünkü Rezervasyon</h4>
                <p class="text-2xl font-bold text-gray-800">@ViewBag.BugunkuRezervasyon</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-5 border-l-4 border-yellow-500">
        <div class="flex items-center">
            <div class="flex-shrink-0 bg-yellow-100 p-3 rounded-full">
                <i class="fas fa-list text-yellow-500 text-xl"></i>
            </div>
            <div class="ml-4">
                <h4 class="text-gray-500 text-sm">Kategoriler</h4>
                <p class="text-2xl font-bold text-gray-800">@ViewBag.KategoriSayisi</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-5 border-l-4 border-purple-500">
        <div class="flex items-center">
            <div class="flex-shrink-0 bg-purple-100 p-3 rounded-full">
                <i class="fas fa-users text-purple-500 text-xl"></i>
            </div>
            <div class="ml-4">
                <h4 class="text-gray-500 text-sm">Aşçılar</h4>
                <p class="text-2xl font-bold text-gray-800">@ViewBag.AsciSayisi</p>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2">Hızlı İşlemler</h3>
        <div class="grid grid-cols-2 gap-4">
            <a asp-controller="Rezervasyon" asp-action="Ekle" class="flex flex-col items-center justify-center p-4 border rounded hover:bg-gray-50 transition cursor-pointer">
                <i class="fas fa-plus-circle text-2xl text-green-500 mb-2"></i>
                <span class="text-sm font-medium">Rezervasyon Ekle</span>
            </a>
            <a asp-controller="Urun" asp-action="Ekle" class="flex flex-col items-center justify-center p-4 border rounded hover:bg-gray-50 transition cursor-pointer">
                <i class="fas fa-hamburger text-2xl text-orange-500 mb-2"></i>
                <span class="text-sm font-medium">Ürün Ekle</span>
            </a>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2">Sistem Durumu</h3>

        <p class="text-gray-600 text-sm">
            <span class="font-bold text-gray-800">Toplam Rezervasyon Kaydı:</span> @ViewBag.ToplamRezervasyon
        </p>

        <p class="text-gray-600 text-sm mt-4 pt-4 border-t border-gray-100">
            <span class="font-bold text-gray-800">Anlık Oturum İşlem Hacmi (Singleton):</span>
            <span class="bg-gray-200 text-gray-800 px-2 py-1 rounded text-xs font-bold">@ViewBag.OturumIslemSayisi</span>
        </p>
    </div>
</div>