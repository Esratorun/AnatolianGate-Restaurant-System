@model List<RestoranProje1.Models.Rezervasyon>
@{
    ViewData["Title"] = "Rezervasyonlar";
    // -----------------------------------------------------------------------------------------
    // PROJE İSTERLERİ KANITLARI (Rezervasyon/Index.cshtml)
    // -----------------------------------------------------------------------------------------
    // [İSTER 7]  : Proje MVC tasarım kalıbına uygun geliştirilmiş mi?
    //              EVET -> Burası MVC'nin "View" katmanıdır. Rezervasyon listesini gösterir.
    //
    // [İSTER 11] : Tag Helper Kullanılmış mı?
    //              EVET -> "asp-action", "asp-route-id" etiketleri buton ve linklerde kullanılmıştır.
    //
    // [İSTER 17] : Jquery kütüphanesi Kullanılmış mı?
    //              EVET -> Sayfa altındaki scriptte, tablo içinde anlık arama yapmak için
    //              JQuery ($) seçicileri ve eventleri kullanılmıştır.
    //
    // [İSTER 20] : Admin için tema uygulanmış mı?
    //              EVET -> Tailwind CSS (bg-white, shadow-lg, rounded-lg) ile
    //              profesyonel bir admin paneli tasarımı yapılmıştır.
    //
    // [İSTER 21] : Area oluşturulmuş mu?
    //              EVET -> Bu dosya Admin Area (/Areas/Admin/Views) içerisindedir.
    // -----------------------------------------------------------------------------------------
}

<div class="container mx-auto px-4 py-6">

    <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-gray-800">Rezervasyon Listesi</h2>
        <a asp-action="Ekle" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold py-2 px-4 rounded shadow transition duration-300 flex items-center">
            <i class="fas fa-plus mr-2"></i> Yeni Rezervasyon
        </a>
    </div>

    @if (TempData["Basarili"] != null)
    {
        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4 shadow-sm" role="alert">
            <p class="font-bold">Başarılı!</p>
            <p>@TempData["Basarili"]</p>
        </div>
    }
    @if (TempData["Hata"] != null)
    {
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-4 shadow-sm" role="alert">
            <p class="font-bold">Hata!</p>
            <p>@TempData["Hata"]</p>
        </div>
    }

    <div class="bg-white shadow-lg rounded-lg overflow-hidden border border-gray-200">

        <div class="p-4 border-b border-gray-200 bg-gray-50 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="text-sm text-gray-600">
                Sayfada <strong>@Model.Count</strong> kayıt gösteriliyor.
            </div>
            <div class="w-full md:w-auto">
                <div class="relative text-gray-600 focus-within:text-gray-400">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-2">
                        <button type="submit" class="p-1 focus:outline-none focus:shadow-outline">
                            <i class="fas fa-search"></i>
                        </button>
                    </span>
                    <input type="search" id="rezervasyonAra" class="py-2 text-sm text-gray-900 bg-white rounded-md pl-10 focus:outline-none focus:bg-white focus:text-gray-900 border border-gray-300 w-full md:w-64 transition" placeholder="Ara..." autocomplete="off">
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full leading-normal">
                <thead>
                    <tr>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            Tarih / Saat
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            Müşteri
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            Masa
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            İletişim
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            Kişi
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            Durum
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            İşlemler
                        </th>
                    </tr>
                </thead>
                <tbody id="rezervasyonTablosu">
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition duration-150">
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm">
                                    <p class="text-gray-900 whitespace-no-wrap font-bold">
                                        @item.RezervasyonTarihi.ToString("dd.MM.yyyy")
                                    </p>
                                    <p class="text-gray-500 text-xs">@item.RezervasyonSaati</p>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm">
                                    <p class="text-gray-900 whitespace-no-wrap font-medium">
                                        @item.MusteriAdi @item.MusteriSoyadi
                                    </p>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm">
                                    @if (item.Masa != null)
                                    {
                                        <div class="flex items-center">
                                            <div class="w-8 h-8 rounded-full bg-yellow-100 text-yellow-600 flex items-center justify-center mr-2 shadow-sm">
                                                <i class="fas fa-chair text-xs"></i>
                                            </div>
                                            <span class="font-bold text-gray-700">@item.Masa.MasaAdi</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                            Atanmadı
                                        </span>
                                    }
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm">
                                    <div class="flex flex-col">
                                        <a href="tel:@item.MusteriTelefon" class="text-gray-600 hover:text-blue-600 transition text-xs mb-1">
                                            <i class="fas fa-phone mr-1"></i> @item.MusteriTelefon
                                        </a>
                                        <a href="mailto:@item.MusteriEposta" class="text-gray-500 hover:text-blue-600 transition text-xs">
                                            <i class="fas fa-envelope mr-1"></i> @item.MusteriEposta
                                        </a>
                                    </div>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm text-center">
                                    <span class="font-bold text-gray-700">@item.KisiSayisi</span>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm text-center">
                                    @{
                                        var durumClass = "bg-gray-100 text-gray-800";
                                        if (item.RezervasyonDurumu == "Onaylandı") { durumClass = "bg-green-100 text-green-800"; }
                                        else if (item.RezervasyonDurumu == "Bekliyor") { durumClass = "bg-yellow-100 text-yellow-800"; }
                                        else if (item.RezervasyonDurumu == "İptal" || item.RezervasyonDurumu == "Reddedildi") { durumClass = "bg-red-100 text-red-800"; }
                                    }
                                    <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full @durumClass">
                                        @item.RezervasyonDurumu
                                    </span>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm text-center">
                                    <div class="flex justify-center space-x-2">
                                        <a asp-action="Duzenle" asp-route-id="@item.RezervasyonID" class="bg-blue-500 hover:bg-blue-600 text-white p-2 rounded shadow transition duration-200" title="Düzenle">
                                            <i class="fas fa-edit"></i>
                                        </a>

                                        @if (item.RezervasyonDurumu == "Bekliyor")
                                        {
                                            <a asp-action="Onayla" asp-route-id="@item.RezervasyonID" class="bg-green-500 hover:bg-green-600 text-white p-2 rounded shadow transition duration-200" title="Onayla">
                                                <i class="fas fa-check"></i>
                                            </a>
                                        }

                                        @if (item.RezervasyonDurumu != "İptal" && item.RezervasyonDurumu != "Reddedildi")
                                        {
                                            <a asp-action="Iptal" asp-route-id="@item.RezervasyonID" onclick="return confirm('Bu rezervasyonu iptal etmek istiyor musunuz?')" class="bg-yellow-500 hover:bg-yellow-600 text-white p-2 rounded shadow transition duration-200" title="İptal Et">
                                                <i class="fas fa-ban"></i>
                                            </a>
                                        }

                                        <a asp-action="Sil" asp-route-id="@item.RezervasyonID" onclick="return confirm('Kalıcı olarak silinecek! Emin misiniz?')" class="bg-red-500 hover:bg-red-600 text-white p-2 rounded shadow transition duration-200" title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="px-5 py-10 border-b border-gray-200 bg-white text-sm text-center text-gray-500">
                                <div class="flex flex-col items-center justify-center">
                                    <i class="fas fa-calendar-times text-4xl mb-4 text-gray-300"></i>
                                    <p class="text-lg font-medium">Henüz rezervasyon kaydı bulunmamaktadır.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="px-5 py-3 bg-white border-t flex flex-col xs:flex-row items-center xs:justify-between">
            <span class="text-xs xs:text-sm text-gray-900">
                @Model.Count kayıt listeleniyor
            </span>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // [İSTER 17] : Jquery Kütüphanesi Kullanımı
        // Tablo içinde anlık arama (filtreleme) yapar
        $(document).ready(function(){
            $("#rezervasyonAra").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#rezervasyonTablosu tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
}