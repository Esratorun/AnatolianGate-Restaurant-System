@model List<RestoranProje1.Models.Musteri>
@{
    ViewData["Title"] = "Müşteriler";
    // -----------------------------------------------------------------------------------------
    // PROJE İSTERLERİ KANITLARI (Musteriler/Index.cshtml)
    // -----------------------------------------------------------------------------------------
    // [İSTER 7]  : Proje MVC tasarım kalıbına uygun geliştirilmiş mi?
    //              EVET -> Burası MVC'nin "View" katmanıdır. Model verisini listeler.
    //
    // [İSTER 11] : Tag Helper Kullanılmış mı?
    //              EVET -> "asp-action" (SenkronizeEt butonu için) kullanılmıştır.
    //
    // [İSTER 17] : Jquery kütüphanesi Kullanılmış mı?
    //              EVET -> Sayfa altındaki "musteriAra" fonksiyonu JQuery ($) ile yazılmıştır.
    //              İstemci taraflı (Client-side) filtreleme yapar.
    //
    // [İSTER 20] : Admin için tema uygulanmış mı?
    //              EVET -> Tailwind CSS (bg-white, shadow-lg, border-gray-200) ile
    //              profesyonel bir admin paneli listeleme tasarımı yapılmıştır.
    //
    // [İSTER 21] : Area oluşturulmuş mu?
    //              EVET -> Bu dosya Admin Area (/Areas/Admin/Views) içerisindedir.
    // -----------------------------------------------------------------------------------------
}

<div class="container mx-auto px-4 py-6">

    <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-gray-800">Müşteri Listesi</h2>

        <a asp-action="SenkronizeEt" class="bg-yellow-500 hover:bg-yellow-600 text-white text-sm font-bold py-2 px-4 rounded shadow transition duration-300 flex items-center">
            <i class="fas fa-sync-alt mr-2 animate-spin-hover"></i> Geçmiş Müşterileri Getir
        </a>
    </div>

    @if (TempData["Basarili"] != null)
    {
        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-4 shadow-sm" role="alert">
            <p class="font-bold">Başarılı!</p>
            <p>@TempData["Basarili"]</p>
        </div>
    }
    @if (TempData["Bilgi"] != null)
    {
        <div class="bg-blue-100 border-l-4 border-blue-500 text-blue-700 p-4 mb-4 shadow-sm" role="alert">
            <p class="font-bold">Bilgi</p>
            <p>@TempData["Bilgi"]</p>
        </div>
    }

    <div class="bg-white shadow-lg rounded-lg overflow-hidden border border-gray-200">

        <div class="p-4 border-b border-gray-200 bg-gray-50 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="text-sm text-gray-600">
                Toplam <strong>@Model.Count</strong> kayıt listeleniyor.
            </div>
            <div class="w-full md:w-auto">
                <div class="relative text-gray-600 focus-within:text-gray-400">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-2">
                        <button type="submit" class="p-1 focus:outline-none focus:shadow-outline">
                            <i class="fas fa-search"></i>
                        </button>
                    </span>
                    <input type="search" id="musteriAra" class="py-2 text-sm text-gray-900 bg-white rounded-md pl-10 focus:outline-none focus:bg-white focus:text-gray-900 border border-gray-300 w-full md:w-64 transition" placeholder="Müşteri Ara..." autocomplete="off">
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full leading-normal">
                <thead>
                    <tr>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            Müşteri Adı
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            Telefon
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            E-Posta
                        </th>
                        <th class="px-5 py-3 border-b-2 border-gray-200 bg-gray-100 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">
                            İşlemler
                        </th>
                    </tr>
                </thead>
                <tbody id="musteriTablosu">
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition duration-150">
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 w-10 h-10">
                                            <div class="w-full h-full rounded-full bg-gradient-to-tr from-blue-400 to-blue-600 flex items-center justify-center text-white font-bold text-lg shadow">
                                                @item.MusteriAdi.Substring(0, 1).ToUpper()
                                            </div>
                                        </div>
                                        <div class="ml-3">
                                            <p class="text-gray-900 font-bold whitespace-no-wrap">
                                                @item.MusteriAdi @item.MusteriSoyadi
                                            </p>
                                            <p class="text-gray-500 text-xs">ID: #@item.MusteriID</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm">
                                    <p class="text-gray-900 whitespace-no-wrap font-medium">
                                        <i class="fas fa-phone-alt text-gray-400 mr-2"></i> @item.MusteriTelefon
                                    </p>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm">
                                    <p class="text-gray-900 whitespace-no-wrap">
                                        <i class="fas fa-envelope text-gray-400 mr-2"></i> @item.MusteriEposta
                                    </p>
                                </td>
                                <td class="px-5 py-4 border-b border-gray-200 bg-white text-sm text-center">
                                    <div class="flex justify-center space-x-2">
                                        <a asp-action="Duzenle" asp-route-id="@item.MusteriID" class="bg-blue-500 hover:bg-blue-600 text-white p-2 rounded shadow transition duration-200" title="Düzenle">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Sil" asp-route-id="@item.MusteriID" onclick="return confirm('Bu müşteriyi ve bağlı tüm verilerini silmek istediğinize emin misiniz?')" class="bg-red-500 hover:bg-red-600 text-white p-2 rounded shadow transition duration-200" title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-5 py-10 border-b border-gray-200 bg-white text-sm text-center text-gray-500">
                                <div class="flex flex-col items-center justify-center">
                                    <i class="fas fa-users-slash text-4xl mb-4 text-gray-300"></i>
                                    <p class="text-lg font-medium">Henüz kayıtlı müşteri bulunmamaktadır.</p>
                                    <p class="text-sm mt-2">Geçmiş rezervasyonları taramak için sağ üstteki butonu kullanın.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="px-5 py-3 bg-white border-t flex flex-col xs:flex-row items-center xs:justify-between">
            <span class="text-xs xs:text-sm text-gray-900">
                Tüm kayıtlar gösteriliyor
            </span>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // [İSTER 17] : Jquery Kütüphanesi Kullanımı
        // Basit Arama Filtresi (Client-Side)
        $(document).ready(function(){
            $("#musteriAra").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#musteriTablosu tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>

    <style>
        .animate-spin-hover:hover {
            animation: spin 1s linear infinite;
        }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }
    </style>
}